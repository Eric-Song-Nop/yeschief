{
  "name": "api",
  "version": "1.0.50",
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config ../../.oxlintrc.json .",
    "lint:fix": "oxlint --config ../../.oxlintrc.json --fix .",
    "format": "oxfmt --config ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.oxfmtignore --write .",
    "format:check": "oxfmt --config ../../.oxfmtrc.json --ignore-path ../../.gitignore --ignore-path ../../.oxfmtignore --check ."
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@livekit/protocol": "^1.45.1",
    "@yes-chief/shared": "workspace:*",
    "elysia": "latest",
    "livekit-server-sdk": "^2.15.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js"
}
