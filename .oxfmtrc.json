{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".codex/", "node_modules/", "**/dist/**"],
  "endOfLine": "lf",
  "experimentalSortPackageJson": false,
  "printWidth": 80,
  "semi": false,
  "singleQuote": false,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false
}
