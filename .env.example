# Required: provide your own LiveKit credentials before `docker compose up --build`
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: the defaults below work with the provided docker compose setup
DATABASE_URL=./apps/api/data/yes-chief.sqlite
PORT=3000
YES_CHIEF_API_BASE_URL=http://api:3000
VITE_API_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
